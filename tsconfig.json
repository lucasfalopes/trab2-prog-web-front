{
  "compilerOptions": {
    "target": "es2016",
    "module": "es6",
    "lib": ["DOM", "ES2016"],
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
